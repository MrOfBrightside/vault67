# ============================================================================
# Section 5: Worktree Management
# ============================================================================

worktree_ensure_repo() {
    if [ ! -d "$BARE_REPO" ]; then
        info "Cloning bare repo..."
        local clone_url="$TARGET_REPO_URL"
        # Inject token for HTTPS auth
        if [[ "$clone_url" == https://* ]] && [ -n "$FORGEJO_TOKEN" ]; then
            clone_url=$(echo "$clone_url" | sed "s|https://|https://oauth2:${FORGEJO_TOKEN}@|")
        fi
        git clone --bare "$clone_url" "$BARE_REPO"
        success "Bare repo cloned"
    else
        log_worker "Fetching latest from origin..."
        local fetch_url="$TARGET_REPO_URL"
        if [[ "$fetch_url" == https://* ]] && [ -n "$FORGEJO_TOKEN" ]; then
            fetch_url=$(echo "$fetch_url" | sed "s|https://|https://oauth2:${FORGEJO_TOKEN}@|")
        fi
        git -C "$BARE_REPO" remote set-url origin "$fetch_url"
        git -C "$BARE_REPO" fetch origin --prune 2>/dev/null || warn "Fetch failed, using cached repo"
    fi
}

worktree_create() {
    local issue_number="$1"
    local base_ref="${2:-$TARGET_REPO_BRANCH}"
    local wt_dir="$WORKTREES_DIR/issue-${issue_number}"
    local branch_name="${BRANCH_PREFIX}/issue-${issue_number}"

    if [ -d "$wt_dir" ]; then
        warn "Worktree already exists: $wt_dir"
        echo "$wt_dir"
        return 0
    fi

    worktree_ensure_repo >&2

    # Create worktree with new branch from base_ref
    # Bare clones store refs under refs/heads/ not refs/remotes/origin/
    # Redirect stdout to stderr so only the path is echoed
    git -C "$BARE_REPO" worktree add "$wt_dir" -b "$branch_name" "${base_ref}" >&2 2>/dev/null \
        || git -C "$BARE_REPO" worktree add "$wt_dir" -B "$branch_name" "${base_ref}" >&2

    # Configure push URL with auth
    local push_url="$TARGET_REPO_URL"
    if [[ "$push_url" == https://* ]] && [ -n "$FORGEJO_TOKEN" ]; then
        push_url=$(echo "$push_url" | sed "s|https://|https://oauth2:${FORGEJO_TOKEN}@|")
    fi
    git -C "$wt_dir" remote set-url origin "$push_url" 2>/dev/null || true

    echo "$wt_dir"
}

worktree_cleanup() {
    local issue_number="$1"
    local wt_dir="$WORKTREES_DIR/issue-${issue_number}"
    local branch_name="${BRANCH_PREFIX}/issue-${issue_number}"

    if [ -d "$wt_dir" ]; then
        git -C "$BARE_REPO" worktree remove "$wt_dir" --force 2>/dev/null || {
            # Fallback: remove directory and prune worktree metadata
            rm -rf "$wt_dir"
            git -C "$BARE_REPO" worktree prune 2>/dev/null || true
        }
    fi
    git -C "$BARE_REPO" branch -D "$branch_name" 2>/dev/null || true

    rm -rf "$LOCKDIR/issue-${issue_number}.lock.d" 2>/dev/null || true
    rm -f "$LOCKDIR/issue-${issue_number}.lock" 2>/dev/null || true
}

# ============================================================================
# Section 6: Code Generation (THE CORE)
# ============================================================================

read_repo_context() {
    local wt_dir="$1"
    local max_chars=32000
    local context=""

    # Get tree structure
    context+="## Repository structure\n\`\`\`\n"
    context+=$(cd "$wt_dir" && tree -I '.git|node_modules|__pycache__|.venv|venv|dist|build|.tox|.mypy_cache' --noreport -L 4 2>/dev/null || find . -maxdepth 4 -not -path './.git/*' | head -200)
    context+="\n\`\`\`\n\n"

    # Read key files (README, setup, config, etc.)
    local key_files=()
    for pattern in "README*" "setup.py" "setup.cfg" "pyproject.toml" "Makefile" "Cargo.toml" "package.json" "go.mod" "Gemfile"; do
        while IFS= read -r f; do
            [ -f "$wt_dir/$f" ] && key_files+=("$f")
        done < <(cd "$wt_dir" && find . -maxdepth 2 -name "$pattern" 2>/dev/null | sed 's|^\./||')
    done

    local current_len=${#context}
    for f in ${key_files[@]+"${key_files[@]}"}; do
        local file_content
        file_content=$(head -c 4000 "$wt_dir/$f" 2>/dev/null) || continue
        local addition="## File: ${f}\n\`\`\`\n${file_content}\n\`\`\`\n\n"
        if (( current_len + ${#addition} < max_chars )); then
            context+="$addition"
            current_len=$((current_len + ${#addition}))
        fi
    done

    echo -e "$context"
}

generate_plan() {
    local promptpack="$1"
    local wt_dir="$2"

    local system_prompt
    system_prompt=$(cat "$PROMPTS_DIR/implement.md" 2>/dev/null || echo "You are a developer. Given a spec and repo structure, output a JSON implementation plan.")

    local repo_context
    repo_context=$(read_repo_context "$wt_dir")

    local user_prompt="# Task
Create an implementation plan for the following specification.

# Specification (from promptpack)
${promptpack}

# Current Repository
${repo_context}

# Output Format
Respond with ONLY a JSON object (no markdown fences, no explanation):
{
  \"files\": [
    {\"path\": \"relative/path.py\", \"action\": \"create\", \"description\": \"what this file does\"},
    {\"path\": \"existing/file.py\", \"action\": \"modify\", \"description\": \"what to change\"}
  ],
  \"commit_message\": \"feat: short description of changes\"
}"

    log_worker "Generating implementation plan..."
    local plan_output
    plan_output=$(ollama_generate "$user_prompt" "$system_prompt") || {
        log_worker "ERROR: Plan generation LLM call failed"
        return 1
    }

    # Extract JSON from response (strip markdown fences, parse)
    local plan_json _plan_tmpfile
    _plan_tmpfile=$(mktemp)
    register_temp_file "$_plan_tmpfile"
    printf '%s' "$plan_output" > "$_plan_tmpfile"
    plan_json=$(parse_llm_json_object "$_plan_tmpfile" "files" 2>/dev/null) || true
    rm -f "$_plan_tmpfile"

    if [ -z "$plan_json" ]; then
        log_worker "ERROR: Could not parse plan JSON from LLM output"
        log_worker "Raw output: ${plan_output:0:500}"
        return 1
    fi

    echo "$plan_json"
}

generate_file() {
    local wt_dir="$1"
    local file_path="$2"
    local action="$3"
    local description="$4"
    local promptpack="$5"

    local system_prompt
    system_prompt=$(cat "$PROMPTS_DIR/generate.md" 2>/dev/null || echo "You are implementing a single file. Output ONLY the complete file content. No markdown fences, no explanation, no commentary.")

    local existing_content=""
    if [ "$action" = "modify" ] && [ -f "$wt_dir/$file_path" ]; then
        existing_content=$(cat "$wt_dir/$file_path" 2>/dev/null)
    fi

    local user_prompt="# Task
${action} file: ${file_path}
Description: ${description}

# Specification context
${promptpack}

"
    if [ -n "$existing_content" ]; then
        user_prompt+="# Current file content
\`\`\`
${existing_content}
\`\`\`

"
    fi

    user_prompt+="# Instructions
Output ONLY the complete file content. No markdown fences. No explanation. No \`\`\` markers.
The output will be written directly to ${file_path}."

    log_worker "  Generating: ${file_path} (${action})"
    local file_content
    file_content=$(ollama_generate "$user_prompt" "$system_prompt") || {
        log_worker "  ERROR: Generation failed for ${file_path}"
        return 1
    }

    # Strip markdown fences if the model added them despite instructions
    file_content=$(python3 -c "
import sys, re
text = sys.argv[1]
# Remove leading/trailing fences
text = re.sub(r'^[ \t]*\`\`\`\w*\n', '', text)
text = re.sub(r'\n[ \t]*\`\`\`[ \t]*$', '', text)
print(text)
" "$file_content")

    echo "$file_content"
}

apply_files() {
    local wt_dir="$1"
    local plan_json="$2"
    local promptpack="$3"

    local file_count
    file_count=$(python3 -c "import json,sys; print(len(json.loads(sys.argv[1])['files']))" "$plan_json")
    log_worker "Generating ${file_count} files..."

    python3 -c "
import json, sys
plan = json.loads(sys.argv[1])
for f in plan['files']:
    print(f'{f[\"action\"]}|{f[\"path\"]}|{f[\"description\"]}')
" "$plan_json" | while IFS='|' read -r action path description; do
        if [ "$action" = "delete" ]; then
            log_worker "  Deleting: ${path}"
            rm -f "$wt_dir/$path"
            continue
        fi

        local content
        content=$(generate_file "$wt_dir" "$path" "$action" "$description" "$promptpack") || {
            warn "Failed to generate ${path}, skipping"
            continue
        }

        # Validate content before writing
        local content_size=${#content}
        if [ "$content_size" -gt 10485760 ]; then
            warn "Generated content for ${path} too large (${content_size} bytes > 10MB), skipping"
            continue
        fi
        if [ -z "$content" ]; then
            warn "Generated empty content for ${path}, skipping"
            continue
        fi
        # Check for null bytes (binary content)
        if printf '%s' "$content" | grep -qP '\x00' 2>/dev/null; then
            warn "Generated content for ${path} contains null bytes (binary?), skipping"
            continue
        fi

        # Ensure parent directory exists
        mkdir -p "$wt_dir/$(dirname "$path")"
        echo "$content" > "$wt_dir/$path"
        log_worker "  Wrote: ${path} ($(wc -c < "$wt_dir/$path") bytes)"
    done
}

# ============================================================================
# Section 7: Validation + Repair
# ============================================================================

run_golden_test() {
    local wt_dir="$1"
    local test_cmd="$2"
    local output_file
    output_file=$(mktemp)
    register_temp_file "$output_file"

    if [ -z "$test_cmd" ]; then
        log_worker "No golden test command — skipping validation"
        rm -f "$output_file"
        return 0
    fi

    log_worker "Running golden test: ${test_cmd}"
    if safe_eval_cmd "$wt_dir" "$test_cmd" > "$output_file" 2>&1; then
        log_worker "Tests PASSED"
        rm -f "$output_file"
        return 0
    else
        log_worker "Tests FAILED"
        cat "$output_file" >&2
        # Keep output for repair
        echo "$output_file"
        return 1
    fi
}

attempt_repair() {
    local wt_dir="$1"
    local test_cmd="$2"
    local test_output_file="$3"
    local promptpack="$4"
    local attempt="$5"

    local test_output
    test_output=$(cat "$test_output_file" 2>/dev/null | head -c 8000)
    rm -f "$test_output_file"

    local system_prompt
    system_prompt=$(cat "$PROMPTS_DIR/fix.md" 2>/dev/null || echo "You are fixing test failures. Output a JSON array of file patches.")

    # Collect changed files
    local changed_files=""
    local diff_output
    diff_output=$(cd "$wt_dir" && git diff --name-only HEAD 2>/dev/null)
    local untracked
    untracked=$(cd "$wt_dir" && git ls-files --others --exclude-standard 2>/dev/null)
    local all_changed="${diff_output}${untracked:+$'\n'$untracked}"

    while IFS= read -r f; do
        [ -z "$f" ] && continue
        [ -f "$wt_dir/$f" ] || continue
        local content
        content=$(head -c 8000 "$wt_dir/$f" 2>/dev/null)
        changed_files+="## File: ${f}
\`\`\`
${content}
\`\`\`

"
    done <<< "$all_changed"

    local messages_json
    messages_json=$(python3 -c "
import json, sys
messages = [
    {'role': 'system', 'content': sys.argv[1]},
    {'role': 'user', 'content': f'''# Test Failure (attempt {sys.argv[4]})

## Test command
{sys.argv[5]}

## Test output (failure)
{sys.argv[2]}

## Changed files
{sys.argv[3]}

# Instructions
Fix the failing tests. Output ONLY a JSON array (no fences, no explanation):
[
  {{\"path\": \"relative/path.py\", \"content\": \"complete file content here\"}}
]
'''}
]
print(json.dumps(messages))
" "$system_prompt" "$test_output" "$changed_files" "$attempt" "$test_cmd")

    log_worker "Attempting repair (attempt ${attempt})..."
    local repair_output
    repair_output=$(ollama_chat "$messages_json") || {
        log_worker "Repair LLM call failed"
        return 1
    }

    # Parse patches
    local patches _ar_tmpfile
    _ar_tmpfile=$(mktemp)
    register_temp_file "$_ar_tmpfile"
    printf '%s' "$repair_output" > "$_ar_tmpfile"
    patches=$(parse_llm_json_array "$_ar_tmpfile" 2>/dev/null) || {
        rm -f "$_ar_tmpfile"
        log_worker "Could not parse repair patches"
        return 1
    }
    rm -f "$_ar_tmpfile"

    # Apply patches
    python3 -c "
import json, sys
patches = json.loads(sys.argv[1])
for p in patches:
    print(f'{p[\"path\"]}')
" "$patches" | while IFS= read -r path; do
        local content
        content=$(python3 -c "
import json, sys
patches = json.loads(sys.argv[1])
for p in patches:
    if p['path'] == sys.argv[2]:
        print(p['content'])
        break
" "$patches" "$path")
        mkdir -p "$wt_dir/$(dirname "$path")"
        echo "$content" > "$wt_dir/$path"
        log_worker "  Patched: ${path}"
    done

    # Re-test
    local new_output_file
    if new_output_file=$(run_golden_test "$wt_dir" "$test_cmd" 2>/dev/null); then
        return 0
    else
        if [ -f "$new_output_file" ]; then
            echo "$new_output_file"  # pass output file for next attempt
        fi
        return 1
    fi
}

# ============================================================================
# Section 7b: Verification Gates
# ============================================================================

# Cache for collect_changed_files — avoids repeated git calls per iteration
# Set _CHANGED_FILES_CACHE="" to invalidate (e.g., after repair modifies files)
_CHANGED_FILES_CACHE=""
_CHANGED_FILES_CACHE_DIR=""

collect_changed_files() {
    local wt_dir="$1"
    local max_per_file="${2:-8000}"

    # Return cached result if same dir and cache is populated
    if [ -n "$_CHANGED_FILES_CACHE" ] && [ "$_CHANGED_FILES_CACHE_DIR" = "$wt_dir" ]; then
        echo "$_CHANGED_FILES_CACHE"
        return 0
    fi

    local changed_files=""
    local diff_output
    diff_output=$(cd "$wt_dir" && git diff --name-only HEAD 2>/dev/null)
    local untracked
    untracked=$(cd "$wt_dir" && git ls-files --others --exclude-standard 2>/dev/null)
    local all_changed="${diff_output}${untracked:+$'\n'$untracked}"

    while IFS= read -r f; do
        [ -z "$f" ] && continue
        [ -f "$wt_dir/$f" ] || continue
        local content
        content=$(head -c "$max_per_file" "$wt_dir/$f" 2>/dev/null)
        changed_files+="## File: ${f}
\`\`\`
${content}
\`\`\`

"
    done <<< "$all_changed"

    # Cache the result
    _CHANGED_FILES_CACHE="$changed_files"
    _CHANGED_FILES_CACHE_DIR="$wt_dir"
    echo "$changed_files"
}

generate_spec_tests() {
    local wt_dir="$1"
    local promptpack="$2"

    if [ "$SKIP_TEST_GENERATION" = "1" ]; then
        log_worker "Spec test generation: SKIPPED (disabled)"
        return 0
    fi

    log_worker "Generating spec-derived tests..."

    local system_prompt
    system_prompt=$(cat "$PROMPTS_DIR/generate_tests.md" 2>/dev/null) || {
        log_worker "Spec test generation: no prompt template — skipping"
        return 0
    }

    # Extract Gherkin scenarios and test strategy from promptpack
    local test_context
    test_context=$(python3 -c "
import sys, re
text = sys.argv[1]

# Extract Gherkin scenarios
gherkin = []
for m in re.finditer(r'(?:Scenario|Feature):.*?(?=\n(?:Scenario|Feature|##|\Z))', text, re.DOTALL):
    gherkin.append(m.group(0).strip())

# Extract test strategy section
strategy = ''
m = re.search(r'(?:## Test Strategy|### Test Strategy|## Testing)(.*?)(?=\n## |\Z)', text, re.DOTALL)
if m:
    strategy = m.group(1).strip()

# Extract acceptance criteria
criteria = ''
m = re.search(r'(?:## Acceptance Criteria|### Acceptance Criteria)(.*?)(?=\n## |\Z)', text, re.DOTALL)
if m:
    criteria = m.group(1).strip()

output = ''
if gherkin:
    output += '## Gherkin Scenarios\n' + '\n\n'.join(gherkin) + '\n\n'
if strategy:
    output += '## Test Strategy\n' + strategy + '\n\n'
if criteria:
    output += '## Acceptance Criteria\n' + criteria + '\n\n'
print(output if output else text[:4000])
" "$promptpack" 2>/dev/null)

    # Find existing test files for style reference
    local existing_tests=""
    local test_files
    test_files=$(cd "$wt_dir" && find . -maxdepth 4 \( -name "test_*" -o -name "*_test.*" -o -name "*.test.*" -o -name "*_spec.*" \) 2>/dev/null | head -3)
    while IFS= read -r tf; do
        [ -z "$tf" ] && continue
        [ -f "$wt_dir/$tf" ] || continue
        existing_tests+="## Existing test: ${tf}
\`\`\`
$(head -c 2000 "$wt_dir/$tf" 2>/dev/null)
\`\`\`

"
    done <<< "$test_files"

    local repo_context
    repo_context=$(read_repo_context "$wt_dir")

    local user_prompt="# Task
Generate test files based on the specification's acceptance criteria and test strategy.

# Specification
${test_context}

# Repository
${repo_context}

${existing_tests:+# Existing test style reference
${existing_tests}}

# Output
Respond with ONLY a JSON array (no fences, no explanation):
[{\"path\": \"tests/test_example.py\", \"content\": \"complete test file content\"}]"

    local result
    result=$(ollama_generate "$user_prompt" "$system_prompt") || {
        log_worker "Spec test generation: LLM call failed — skipping"
        return 0
    }

    # Parse JSON array
    local test_files_json _st_tmpfile
    _st_tmpfile=$(mktemp)
    register_temp_file "$_st_tmpfile"
    printf '%s' "$result" > "$_st_tmpfile"
    test_files_json=$(parse_llm_json_array "$_st_tmpfile" 2>/dev/null) || {
        rm -f "$_st_tmpfile"
        log_worker "Spec test generation: parse failed — skipping"
        return 0
    }
    rm -f "$_st_tmpfile"

    # Write test files
    python3 -c "
import json, sys
for f in json.loads(sys.argv[1]):
    print(f['path'])
" "$test_files_json" | while IFS= read -r path; do
        local content
