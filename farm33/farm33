# ollama_generate() is provided by lib/common.bash (sourced via lib/helpers.bash)

ollama_chat() {
    local messages_json="$1"
    local response_file
    response_file=$(mktemp)
    register_temp_file "$response_file"

    local json_payload
    json_payload=$(python3 -c "
import json, sys
messages = json.loads(sys.argv[1])
print(json.dumps({
    'model': sys.argv[2],
    'messages': messages,
    'stream': False
}))
" "$messages_json" "$OLLAMA_MODEL")

    local http_code
    http_code=$(curl -s -w "%{http_code}" --connect-timeout 10 --max-time "$OLLAMA_TIMEOUT" \
        -X POST "${OLLAMA_URL}/api/chat" \
        -H "Content-Type: application/json" \
        -d "$json_payload" \
        -o "$response_file" 2>/dev/null) || {
        rm -f "$response_file"
        return 1
    }

    if [[ "$http_code" != "200" ]]; then
        rm -f "$response_file"
        return 1
    fi

    local response_text
    response_text=$(python3 -c "
import json, sys
data = json.load(open(sys.argv[1]))
msg = data.get('message', {})
print(msg.get('content', ''))
" "$response_file" 2>/dev/null)

    rm -f "$response_file"
    [ -z "$response_text" ] && return 1
    echo "$response_text"
}

# ============================================================================
# Section 4: Promptpack Extraction
# ============================================================================

extract_promptpack() {
    local issue_number="$1"

    local comments
    comments=$(api_get_comments "$issue_number") || error "Failed to fetch comments for #${issue_number}"

    # Search comments for "Ready for Implementation" promptpack
    local promptpack
    promptpack=$(python3 -c "
import sys, json, re

comments = json.loads(sys.argv[1])

# Search from most recent to oldest
for comment in reversed(comments):
    body = comment.get('body', '')
    if '## ✅ Ready for Implementation' in body or 'Promptpack' in body:
        # Extract content from <details> block
        match = re.search(r'<details>.*?<summary>.*?</summary>\s*(.*?)\s*</details>', body, re.DOTALL)
        if match:
            print(match.group(1).strip())
            sys.exit(0)

# Fallback: check issue body
sys.exit(1)
" "$comments" 2>/dev/null)

    if [ -n "$promptpack" ]; then
        echo "$promptpack"
        return 0
    fi

    # Fallback: use issue body
    local issue_data
    issue_data=$(api_get_issue "$issue_number")
    local body
    body=$(echo "$issue_data" | extract_issue_body)

    # Try extracting from body's <details> block
    local body_promptpack
    body_promptpack=$(python3 -c "
import sys, re
body = sys.argv[1]
match = re.search(r'<details>.*?<summary>.*?</summary>\s*(.*?)\s*</details>', body, re.DOTALL)
if match:
    print(match.group(1).strip())
else:
    print(body)
" "$body" 2>/dev/null)

    echo "$body_promptpack"
}

