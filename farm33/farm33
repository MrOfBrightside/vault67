commit_changes() {
    local wt_dir="$1"
    local commit_message="$2"

    (
        cd "$wt_dir"
        git add -A
        if ! git diff --cached --quiet; then
            git commit -m "$commit_message"
            log_worker "Committed: ${commit_message}"
        else
            log_worker "No changes to commit"
            return 1
        fi
    )
}

push_branch() {
    local wt_dir="$1"
    local branch_name="$2"

    (
        cd "$wt_dir"
        if git push origin "$branch_name" --force-with-lease 2>&1; then
            log_worker "Pushed branch: ${branch_name}"
        else
            log_worker "Push failed for branch: ${branch_name} (force-with-lease rejected — concurrent changes?)"
            log_structured error "push failed: ${branch_name}"
            return 1
        fi
    )
}

create_pr() {
    local issue_number="$1"
    local commit_message="$2"
    local is_draft="$3"
    local base_ref="${4:-$TARGET_REPO_BRANCH}"
    local spec_review="${5:-SKIP}"
    local tests_result="${6:-SKIP}"
    local acceptance="${7:-SKIP}"
    local confidence="${8:-50}"
    local branch_name="${BRANCH_PREFIX}/issue-${issue_number}"

    local pr_title
    if [ "$is_draft" = "true" ]; then
        pr_title="[DRAFT] ${commit_message}"
    else
        pr_title="${commit_message}"
    fi

    local pr_body
    pr_body="## Auto-generated by farm33

Implements #${issue_number}

### Verification Results

| Check | Result |
|-------|--------|
| Spec review | ${spec_review} |
| Golden tests | ${tests_result} |
| Acceptance criteria | ${acceptance} |
| Diff confidence | ${confidence}/100 (threshold: ${DIFF_REVIEW_THRESHOLD}) |

### Generated by
