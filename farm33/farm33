# ============================================================================
# Section 8b: Refinement Gate Functions
# ============================================================================
# Each gate: returns 0=pass, 1=fail. Appends feedback to GATE_FEEDBACK global.
# Sets global tracking vars for post-loop reporting.

# Gate 1: Spec review — does the code match the spec?
run_spec_review_gate() {
    local wt_dir="$1"
    local promptpack="$2"

    _LAST_SPEC_REVIEW_RESULT=$(verify_spec_review "$wt_dir" "$promptpack") || true
    local verdict
    verdict=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('verdict','pass'))" "$_LAST_SPEC_REVIEW_RESULT")

    if [ "$verdict" = "fail" ] || [ "$verdict" = "error" ]; then
        local gaps
        gaps=$(python3 -c "
import json, sys
r = json.loads(sys.argv[1])
for g in r.get('gaps', []):
    if g.get('status') != 'met':
        print(f\"- {g.get('requirement','?')}: {g.get('detail','')}\")
" "$_LAST_SPEC_REVIEW_RESULT")
        GATE_FEEDBACK+="## Spec Review FAILED
${gaps}

"
        return 1
    fi
    return 0
}

# Gate 2: Golden build — does it compile/build?
run_build_gate() {
    local wt_dir="$1"
    local build_cmd="$2"

    [ -z "$build_cmd" ] && return 0

    local build_output_file
    build_output_file=$(mktemp)
    register_temp_file "$build_output_file"
    if safe_eval_cmd "$wt_dir" "$build_cmd" > "$build_output_file" 2>&1; then
        rm -f "$build_output_file"
        log_worker "Build PASSED"
        log_structured info "build passed"
        return 0
    else
        local build_errors
        build_errors=$(head -c 8000 "$build_output_file" 2>/dev/null)
        rm -f "$build_output_file"
        GATE_FEEDBACK+="## Build FAILED
Command: ${build_cmd}
Output:
${build_errors}

"
        log_worker "Build FAILED"
        log_structured error "build failed"
        return 1
    fi
}

# Gate 3: Golden tests — do tests pass?
run_test_gate() {
    local wt_dir="$1"
    local test_cmd="$2"

    _LAST_TESTS_PASSED="true"
    [ -z "$test_cmd" ] && return 0

    local test_output_file
    test_output_file=$(mktemp)
    register_temp_file "$test_output_file"
    if safe_eval_cmd "$wt_dir" "$test_cmd" > "$test_output_file" 2>&1; then
        log_worker "Tests PASSED"
        log_structured info "tests passed"
        rm -f "$test_output_file"
        return 0
    else
        _LAST_TESTS_PASSED="false"
        local test_errors
        test_errors=$(head -c 8000 "$test_output_file" 2>/dev/null)
        rm -f "$test_output_file"
        GATE_FEEDBACK+="## Tests FAILED
Command: ${test_cmd}
Output:
${test_errors}

"
        log_worker "Tests FAILED"
        log_structured error "tests failed"
        return 1
    fi
}

# Gate 4: Acceptance criteria — are all scenarios satisfied?
run_acceptance_gate() {
    local wt_dir="$1"
    local promptpack="$2"

    _LAST_ACCEPTANCE_RESULT=$(verify_acceptance_criteria "$wt_dir" "$promptpack") || true
    local all_satisfied
    all_satisfied=$(python3 -c "import json,sys; print(str(json.loads(sys.argv[1]).get('all_satisfied',True)).lower())" "$_LAST_ACCEPTANCE_RESULT")

    if [ "$all_satisfied" = "false" ] || python3 -c "import json,sys; sys.exit(0 if 'error' in json.loads(sys.argv[1]) else 1)" "$_LAST_ACCEPTANCE_RESULT" 2>/dev/null; then
        local acc_gaps
        acc_gaps=$(python3 -c "
import json, sys
r = json.loads(sys.argv[1])
for s in r.get('scenarios', []):
    if not s.get('satisfied', True):
        print(f\"- {s.get('name','?')}: {s.get('gaps','')}\")
" "$_LAST_ACCEPTANCE_RESULT")
        GATE_FEEDBACK+="## Acceptance Criteria FAILED
${acc_gaps}

"
        return 1
    fi
    return 0
}

# ============================================================================
# Section 9: Worker Lifecycle
# ============================================================================

worker_run() {
    local issue_number="$1"
    local worker_id="${2:-0}"
    export WORKER_ID="$worker_id"

    # Create lockfile (atomic mkdir for issue lock)
    local lock_path="$LOCKDIR/issue-${issue_number}.lock.d"
    mkdir -p "$lock_path" 2>/dev/null || true
    echo "$worker_id" > "$lock_path/worker"
    echo "$issue_number" > "$LOCKDIR/worker-${worker_id}.lock"

    export CURRENT_ISSUE="$issue_number"
    log_worker "=== Starting work on issue #${issue_number} ==="
    log_structured info "issue picked up by worker"

    # Step 1: Claim issue
    log_worker "Claiming issue #${issue_number}..."
    api_replace_labels "$issue_number" "state:IMPLEMENTING" > /dev/null 2>&1 || warn "Failed to set IMPLEMENTING label on #${issue_number}"
    api_add_comment "$issue_number" "🤖 **farm33** — Implementation started (worker ${worker_id}, model: ${OLLAMA_MODEL})" > /dev/null 2>&1 || warn "Failed to add start comment on #${issue_number}"

    local exit_status=0

    # Subshell for cleanup on failure
    (
        # Step 2: Extract promptpack
        log_worker "Extracting promptpack..."
        local promptpack
        promptpack=$(extract_promptpack "$issue_number") || error "No promptpack found for #${issue_number}"

        # Parse golden commands
        local golden_cmds
        golden_cmds=$(extract_golden_commands "$promptpack")
        local build_cmd test_cmd
        build_cmd=$(echo "$golden_cmds" | grep '^BUILD_CMD=' | cut -d= -f2-)
        test_cmd=$(echo "$golden_cmds" | grep '^TEST_CMD=' | cut -d= -f2-)

        # Parse base ref
        local base_ref
        base_ref=$(extract_base_ref "$promptpack")
        log_worker "Base ref: ${base_ref}, Build: ${build_cmd:-none}, Test: ${test_cmd:-none}"

        # Step 3: Create worktree
        log_worker "Creating worktree..."
        local wt_dir
        wt_dir=$(worktree_create "$issue_number" "$base_ref")
        log_worker "Worktree: ${wt_dir}"

        # Step 4: Generate plan
        log_structured info "build started — generating plan"
        local plan_json
        plan_json=$(generate_plan "$promptpack" "$wt_dir") || error "Plan generation failed"
        log_worker "Plan: $(echo "$plan_json" | python3 -c "import sys,json; d=json.load(sys.stdin); print(f'{len(d[\"files\"])} files, commit: {d[\"commit_message\"]}')" 2>/dev/null)"

        # Step 5: Generate files
        apply_files "$wt_dir" "$plan_json" "$promptpack"
        log_structured info "code generation complete"

        # Step 6: Generate spec-derived tests
        generate_spec_tests "$wt_dir" "$promptpack"

        # ==============================================================
        # REFINEMENT LOOP — All gates verify, repair, repeat
        # Like Gas Town: agents verify each other in a loop until ready
        # ==============================================================
        local max_refinements="$MAX_REFINEMENT_ITERATIONS"
        local iteration=0
        local all_gates_pass=false

        # Globals used by gate functions for post-loop reporting
        _LAST_SPEC_REVIEW_RESULT='{"verdict":"skip","confidence":0,"gaps":[]}'
        _LAST_TESTS_PASSED="true"
        _LAST_ACCEPTANCE_RESULT='{"all_satisfied":true,"scenarios":[]}'
        local _prev_feedback_hash=""

        while [ "$iteration" -lt "$max_refinements" ]; do
            iteration=$((iteration + 1))
            _CHANGED_FILES_CACHE=""
            GATE_FEEDBACK=""
            local gates_ok=true

            log_worker "━━━ Refinement iteration ${iteration}/${max_refinements} ━━━"

            run_spec_review_gate "$wt_dir" "$promptpack"   || gates_ok=false
            run_build_gate "$wt_dir" "$build_cmd"           || gates_ok=false
            run_test_gate "$wt_dir" "$test_cmd"             || gates_ok=false
            run_acceptance_gate "$wt_dir" "$promptpack"     || gates_ok=false

            if [ "$gates_ok" = "true" ]; then
                log_worker "✅ All gates PASSED on iteration ${iteration} — ready"
                log_structured info "all gates passed (iteration ${iteration})"
                all_gates_pass=true
                break
            fi

            log_worker "Gates failed on iteration ${iteration}"

            # Convergence detection: bail if same errors repeat
            local _cur_feedback_hash
            _cur_feedback_hash=$(printf '%s' "$GATE_FEEDBACK" | md5sum 2>/dev/null | cut -d' ' -f1 || printf '%s' "$GATE_FEEDBACK" | md5 2>/dev/null)
            if [ -n "$_prev_feedback_hash" ] && [ "$_cur_feedback_hash" = "$_prev_feedback_hash" ]; then
                log_worker "Convergence detected — same errors repeating, stopping refinement"
                log_structured warn "refinement converged (iteration ${iteration}) — same gate failures"
                break
            fi
            _prev_feedback_hash="$_cur_feedback_hash"

            if [ "$iteration" -lt "$max_refinements" ]; then
                refinement_repair "$wt_dir" "$promptpack" "$GATE_FEEDBACK" "$iteration" || {
                    log_worker "Repair failed — continuing to next iteration"
                }
            else
                log_worker "Max refinement iterations (${max_refinements}) reached"
            fi
        done

        # ==============================================================
        # POST-REFINEMENT: Commit → Diff review → Push → PR
        # ==============================================================

        # Commit
        local commit_message
        commit_message=$(python3 -c "import json,sys; print(json.loads(sys.argv[1])['commit_message'])" "$plan_json" 2>/dev/null || echo "feat: implement #${issue_number}")
        commit_changes "$wt_dir" "$commit_message" || {
            warn "Nothing to commit"
        }

        # Diff review (advisory, post-commit, determines draft status)
        local confidence
        confidence=$(verify_diff_review "$wt_dir" "$promptpack") || confidence=0

        # Push
        local push_failed=false
        push_branch "$wt_dir" "${BRANCH_PREFIX}/issue-${issue_number}" || {
            push_failed=true
            warn "Push failed — PR will be marked as draft"
        }

        # Determine final verdict
        local is_draft="false"
        if [ "$push_failed" = "true" ]; then
            is_draft="true"
        fi
        if [ "$all_gates_pass" != "true" ]; then
            is_draft="true"
        fi
        if [ "${confidence:-0}" -lt "$DIFF_REVIEW_THRESHOLD" ]; then
            is_draft="true"
        fi

        # Build display strings for PR
        local spec_verdict_display
        spec_verdict_display=$(python3 -c "import json,sys; v=json.loads(sys.argv[1]).get('verdict','skip'); c=json.loads(sys.argv[1]).get('confidence',0); print(f'{v.upper()} ({c}/100)')" "$_LAST_SPEC_REVIEW_RESULT" 2>/dev/null || echo "SKIP")
        local acc_display
        acc_display=$(python3 -c "import json,sys; r=json.loads(sys.argv[1]); s=r.get('all_satisfied',True); n=len(r.get('scenarios',[])); print(f'ALL SATISFIED ({n} scenarios)' if s else f'GAPS REMAIN ({n} scenarios)')" "$_LAST_ACCEPTANCE_RESULT" 2>/dev/null || echo "SKIP")
        local tests_display
        if [ "$_LAST_TESTS_PASSED" = "true" ]; then
            tests_display="PASS"
        else
            tests_display="FAIL"
        fi

        # Create PR with verification results
        local pr_url=""
        pr_url=$(create_pr "$issue_number" "$commit_message" "$is_draft" "$base_ref" \
            "$spec_verdict_display" "$tests_display" "$acc_display" "${confidence:-50}" 2>/dev/null) || true

        # Update issue state based on final verdict
        if [ "$is_draft" = "false" ]; then
            log_worker "✅ Issue #${issue_number} — DONE (all gates passed, confidence: ${confidence})"
            log_structured info "issue complete — all gates passed, confidence ${confidence}"
            api_replace_labels "$issue_number" "state:DONE" > /dev/null 2>&1 || warn "Failed to set DONE label on #${issue_number}"
            local done_comment="🤖 **farm33** — Implementation complete ✅

| Check | Result |
|-------|--------|
| Spec review | ${spec_verdict_display} |
| Golden tests | ${tests_display} |
| Acceptance | ${acc_display} |
| Diff confidence | ${confidence}/100 |
| Refinement iterations | ${iteration}/${max_refinements} |"
            [ -n "$pr_url" ] && done_comment+="

PR: ${pr_url}"
            api_add_comment "$issue_number" "$done_comment" > /dev/null 2>&1 || warn "Failed to add done comment on #${issue_number}"
            api_close_issue "$issue_number" > /dev/null 2>&1 || warn "Failed to close #${issue_number}"
        else
            log_worker "⚠️ Issue #${issue_number} — pushed as draft (gates: $([ "$all_gates_pass" = "true" ] && echo "passed" || echo "failed"), confidence: ${confidence:-50})"
            log_structured warn "issue pushed as draft — gates $([ "$all_gates_pass" = "true" ] && echo "passed" || echo "failed"), confidence ${confidence:-50}"
            api_replace_labels "$issue_number" "state:READY_TO_IMPLEMENT" > /dev/null 2>&1 || warn "Failed to set READY_TO_IMPLEMENT label on #${issue_number}"
            local fail_comment="🤖 **farm33** — Implementation pushed as draft PR

| Check | Result |
|-------|--------|
| Spec review | ${spec_verdict_display} |
| Golden tests | ${tests_display} |
| Acceptance | ${acc_display} |
| Diff confidence | ${confidence:-50}/100 (threshold: ${DIFF_REVIEW_THRESHOLD}) |
| Refinement iterations | ${iteration}/${max_refinements} |"
            [ -n "$pr_url" ] && fail_comment+="

Draft PR: ${pr_url}"
            fail_comment+="
Reverting to READY_TO_IMPLEMENT for retry."
            api_add_comment "$issue_number" "$fail_comment" > /dev/null 2>&1 || warn "Failed to add draft comment on #${issue_number}"
        fi

        # Cleanup worktree
        log_worker "Cleaning up worktree..."
        worktree_cleanup "$issue_number"

    ) || exit_status=$?

    # Remove lockfiles
    rm -f "$LOCKDIR/worker-${worker_id}.lock"
    rm -rf "$LOCKDIR/issue-${issue_number}.lock.d" 2>/dev/null || true
    rm -f "$LOCKDIR/issue-${issue_number}.lock" 2>/dev/null || true

    log_worker "=== Finished issue #${issue_number} (exit: ${exit_status}) ==="
    log_structured info "worker finished issue (exit: ${exit_status})"
    unset CURRENT_ISSUE
    return $exit_status
}

# ============================================================================
# Section 10: Pool Manager
# ============================================================================

pool_find_free() {
    local i=0
    while [ "$i" -lt "$POOL_SIZE" ]; do
        if ! tmux has-session -t "farm33-worker-${i}" 2>/dev/null; then
            echo "$i"
            return 0
        fi
        i=$((i + 1))
    done
    return 1
}

pool_dispatch() {
    local issue_number="$1"

    # Atomic lock via mkdir (fails if dir already exists = already locked)
    local lock_path="$LOCKDIR/issue-${issue_number}.lock.d"
    if ! mkdir "$lock_path" 2>/dev/null; then
        warn "Issue #${issue_number} already in progress (locked)"
        return 1
    fi

    local worker_id
    worker_id=$(pool_find_free) || {
        rmdir "$lock_path" 2>/dev/null || true
        warn "No free worker slots (pool size: ${POOL_SIZE})"
        return 1
    }

    # Write lock metadata after atomic claim
    echo "$worker_id" > "$lock_path/worker"
    echo "$issue_number" > "$LOCKDIR/worker-${worker_id}.lock"

    info "Dispatching #${issue_number} to worker ${worker_id}"
    WORKER_ID="$worker_id" CURRENT_ISSUE="$issue_number" \
        log_structured info "issue dispatched to worker"
    tmux new-session -d -s "farm33-worker-${worker_id}" \
        "bash -c '\"$SCRIPT_DIR/farm33\" _worker ${issue_number} ${worker_id} 2>&1 | tee \"$LOGS_DIR/worker-${worker_id}.log\"'"

    success "Worker ${worker_id} started for #${issue_number}"
}

pool_status() {
    echo -e "${CYAN}farm33 worker pool${NC} (size: ${POOL_SIZE})"
    echo "─────────────────────────────────────"

    local active=0
    local i=0
    while [ "$i" -lt "$POOL_SIZE" ]; do
        if tmux has-session -t "farm33-worker-${i}" 2>/dev/null; then
            local issue="?"
            [ -f "$LOCKDIR/worker-${i}.lock" ] && issue=$(cat "$LOCKDIR/worker-${i}.lock")
            echo -e "  worker-${i}: ${GREEN}active${NC} — issue #${issue}"
            active=$((active + 1))
        else
            echo -e "  worker-${i}: ${BLUE}idle${NC}"
        fi
        i=$((i + 1))
    done

    echo "─────────────────────────────────────"
    echo "Active: ${active}/${POOL_SIZE}"
}

# ============================================================================
# Section 11: Commands
# ============================================================================

cmd_run() {
    local issue_number="$1"
    local dry_run="${2:-false}"

    require_api_config

    if [ "$dry_run" = "true" ]; then
        info "Dry run for issue #${issue_number}"
        local issue_data
        issue_data=$(api_get_issue "$issue_number")
        local title
        title=$(echo "$issue_data" | extract_issue_title)
        local labels
        labels=$(echo "$issue_data" | extract_issue_labels)
        echo "Title: ${title}"
        echo "Labels: ${labels}"

        local promptpack
        promptpack=$(extract_promptpack "$issue_number")
        echo ""
        echo "=== Promptpack (first 500 chars) ==="
        echo "${promptpack:0:500}"
        echo ""

        local golden_cmds
        golden_cmds=$(extract_golden_commands "$promptpack")
        echo "=== Golden commands ==="
        echo "$golden_cmds"

        local base_ref
        base_ref=$(extract_base_ref "$promptpack")
        echo "Base ref: ${base_ref}"
        return 0
    fi

    require_ollama
    worker_run "$issue_number" "solo"
}

cmd_batch() {
    local issues=("$@")

    require_api_config

    # If no issues specified, fetch all ready issues
    if [ ${#issues[@]} -eq 0 ]; then
        info "Fetching READY_TO_IMPLEMENT issues..."
        local ready
        ready=$(api_list_ready_issues)
        if [ -z "$ready" ]; then
            info "No issues ready for implementation"
            return 0
        fi
        while IFS= read -r num; do
            [ -n "$num" ] && issues+=("$num")
        done <<< "$ready"
    fi

    info "Dispatching ${#issues[@]} issues to worker pool..."

    for issue_number in "${issues[@]}"; do
        # Skip if already locked (check both old and new lock formats)
        if [ -d "$LOCKDIR/issue-${issue_number}.lock.d" ] || [ -f "$LOCKDIR/issue-${issue_number}.lock" ]; then
            warn "Skipping #${issue_number} — already in progress"
            continue
        fi

        # Check dependencies
        local blockers
        blockers=$(api_check_deps_resolved "$issue_number" 2>/dev/null) && true
        if [ -n "$blockers" ]; then
            warn "Skipping #${issue_number} — blocked by #$(echo "$blockers" | tr '\n' ',')"
            continue
        fi

        # Check for has:subtasks label (skip parent issues)
        local issue_data
        issue_data=$(api_get_issue "$issue_number" 2>/dev/null) || continue
        local labels
        labels=$(echo "$issue_data" | extract_issue_labels 2>/dev/null) || true
        if echo "$labels" | grep -q "has:subtasks"; then
            warn "Skipping #${issue_number} — parent issue (has:subtasks)"
            continue
        fi

        pool_dispatch "$issue_number" || continue
    done
}

cmd_watch() {
    if [ -f "$SCRIPT_DIR/farm33-watch" ]; then
        exec "$SCRIPT_DIR/farm33-watch" "$@"
    else
        error "farm33-watch not found"
    fi
}

cmd_status() {
    pool_status
}

cmd_logs() {
    local worker_id="${1:-}"

    if [ -z "$worker_id" ]; then
        # Show all recent logs
        for f in "$LOGS_DIR"/worker-*.log; do
            [ -f "$f" ] || continue
            echo -e "${CYAN}=== $(basename "$f") ===${NC}"
            tail -20 "$f"
            echo ""
        done
    else
        local log_file="$LOGS_DIR/worker-${worker_id}.log"
        if [ -f "$log_file" ]; then
            tail -f "$log_file"
        else
            error "No log file for worker ${worker_id}"
        fi
    fi
}

cmd_stop() {
    local target="${1:-all}"

    if [ "$target" = "all" ]; then
        local i=0
        while [ "$i" -lt "$POOL_SIZE" ]; do
            if tmux has-session -t "farm33-worker-${i}" 2>/dev/null; then
                tmux kill-session -t "farm33-worker-${i}" 2>/dev/null || true
                info "Stopped worker ${i}"
            fi
            i=$((i + 1))
        done
        rm -f "$LOCKDIR"/*.lock
        success "All workers stopped"
    else
        if tmux has-session -t "farm33-worker-${target}" 2>/dev/null; then
            tmux kill-session -t "farm33-worker-${target}" 2>/dev/null || true
            rm -f "$LOCKDIR/worker-${target}.lock"
            success "Stopped worker ${target}"
        else
            warn "Worker ${target} not running"
        fi
    fi
}

cmd_cleanup() {
    info "Cleaning up stale worktrees and lockfiles..."

    # Remove lockfiles for non-running workers
    local i=0
    while [ "$i" -lt "$POOL_SIZE" ]; do
        if ! tmux has-session -t "farm33-worker-${i}" 2>/dev/null; then
            rm -f "$LOCKDIR/worker-${i}.lock"
        fi
        i=$((i + 1))
    done

    # Remove orphaned issue lockfiles (both old and new format)
    for lockfile in "$LOCKDIR"/issue-*.lock "$LOCKDIR"/issue-*.lock.d; do
        [ -e "$lockfile" ] || continue
        local wid
        if [ -d "$lockfile" ]; then
            wid=$(cat "$lockfile/worker" 2>/dev/null)
        else
            wid=$(cat "$lockfile" 2>/dev/null)
        fi
        if [ -z "$wid" ] || ! tmux has-session -t "farm33-worker-${wid}" 2>/dev/null; then
            rm -rf "$lockfile"
        fi
    done

    # Remove worktrees not associated with active workers
    for wt_dir in "$WORKTREES_DIR"/issue-*; do
        [ -d "$wt_dir" ] || continue
        local issue_num
        issue_num=$(basename "$wt_dir" | sed 's/issue-//')
        if [ ! -d "$LOCKDIR/issue-${issue_num}.lock.d" ] && [ ! -f "$LOCKDIR/issue-${issue_num}.lock" ]; then
            info "Removing stale worktree: ${wt_dir}"
            worktree_cleanup "$issue_num"
        fi
    done

    success "Cleanup complete"
}

cmd_list() {
    require_api_config
    info "Fetching READY_TO_IMPLEMENT issues..."
    local issues
    issues=$(api_list_ready_issues)

    if [ -z "$issues" ]; then
        info "No issues ready for implementation"
        return 0
    fi

    echo -e "${CYAN}Issues ready for implementation:${NC}"
    echo "─────────────────────────────────"
    while IFS= read -r num; do
        [ -z "$num" ] && continue
        local issue_data
        issue_data=$(api_get_issue "$num" 2>/dev/null) || continue
        local title
        title=$(echo "$issue_data" | extract_issue_title 2>/dev/null) || title="?"
        local labels
        labels=$(echo "$issue_data" | extract_issue_labels 2>/dev/null) || labels=""

        local status_icon="📋"
        if [ -d "$LOCKDIR/issue-${num}.lock.d" ] || [ -f "$LOCKDIR/issue-${num}.lock" ]; then
            status_icon="🔨"
        fi
        if echo "$labels" | grep -q "has:subtasks"; then
            status_icon="📦"
        fi

        echo "  ${status_icon} #${num}: ${title}"
    done <<< "$issues"
}

# ============================================================================
# Section 12: Dispatcher + Help
# ============================================================================

show_help() {
    cat <<'HELP'
farm33 - Standalone implementation farm for vault67-refined specs

Usage: farm33 <command> [args]

Commands:
  run <issue> [--dry-run]   Run single issue synchronously
  batch [issues...]         Dispatch to worker pool (no args = all ready)
  list                      List issues ready for implementation
  watch                     Start daemon polling mode
  status                    Show worker pool status
  logs [worker-id]          View worker logs (tail -f with id)
  stop [worker-id|all]      Stop worker(s)
  cleanup                   Remove stale worktrees + lockfiles

Configuration:
  Copy .farm33.conf.example to .farm33.conf and set your tokens.

Environment:
  FORGEJO_TOKEN            Forgejo API token
  FORGEJO_API              Forgejo API URL
  FORGEJO_REPO             Owner/Repo
  OLLAMA_URL               Ollama API URL (default: http://localhost:11434)
  OLLAMA_MODEL             Model name (default: qwen2.5-coder:14b)
  POOL_SIZE                Worker pool size (default: 3)
  FARM33_STRUCTURED_LOG    Path for JSON-formatted structured log (optional)
HELP
}

main() {
    load_config

    local command="${1:-help}"
    shift || true

    case "$command" in
        run)
            local issue="${1:-}"
            [ -z "$issue" ] && error "Usage: farm33 run <issue-number> [--dry-run]"
            shift
            local dry_run="false"
            [ "${1:-}" = "--dry-run" ] && dry_run="true"
            cmd_run "$issue" "$dry_run"
            ;;
        batch)
            cmd_batch "$@"
            ;;
        list)
            cmd_list
            ;;
        watch)
            cmd_watch "$@"
            ;;
        status)
            cmd_status
            ;;
        logs)
            cmd_logs "${1:-}"
            ;;
        stop)
            cmd_stop "${1:-all}"
            ;;
        cleanup)
            cmd_cleanup
            ;;
        _worker)
            # Internal: called by pool_dispatch via tmux
            local issue="${1:-}"
            local wid="${2:-0}"
            [ -z "$issue" ] && error "Usage: farm33 _worker <issue> <worker-id>"
            require_api_config
            require_ollama
            worker_run "$issue" "$wid"
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            error "Unknown command: ${command}. Run 'farm33 help' for usage."
            ;;
    esac
}

main "$@"
