verify_spec_review() {
    local wt_dir="$1"
    local promptpack="$2"

    if [ "$SKIP_SPEC_REVIEW" = "1" ]; then
        log_worker "Spec review: SKIPPED (disabled)"
        echo '{"verdict":"pass","confidence":0,"gaps":[]}'
        return 0
    fi

    log_worker "Running spec review..."

    local system_prompt
    system_prompt=$(cat "$PROMPTS_DIR/review.md" 2>/dev/null) || {
        log_worker "Spec review: no prompt template — skipping"
        echo '{"verdict":"pass","confidence":0,"gaps":[]}'
        return 0
    }

    # Build diff: tracked changes + new untracked files
    local diff
    diff=$(cd "$wt_dir" && git diff HEAD 2>/dev/null | head -c 16000)
    local untracked_diff=""
    local untracked
    untracked=$(cd "$wt_dir" && git ls-files --others --exclude-standard 2>/dev/null)
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        [ -f "$wt_dir/$f" ] || continue
        untracked_diff+="--- /dev/null
+++ b/${f}
$(head -c 4000 "$wt_dir/$f" 2>/dev/null)

"
    done <<< "$untracked"

    local full_diff="${diff}${untracked_diff:+$'\n'$untracked_diff}"

    local user_prompt="# Spec Review
Review whether the code changes satisfy the specification.

## Specification
<user-spec>
${promptpack}
</user-spec>

## Code changes (git diff)
<user-code>
${full_diff}
</user-code>

## Output
Respond with ONLY a JSON object (no fences):
{\"verdict\": \"pass\" or \"fail\", \"confidence\": 0-100, \"gaps\": [{\"requirement\": \"what spec requires\", \"status\": \"met\" or \"missing\" or \"partial\", \"detail\": \"explanation\"}]}"

    local result
    result=$(ollama_generate "$user_prompt" "$system_prompt") || {
        log_worker "Spec review: LLM call failed — returning error verdict"
        echo '{"verdict":"error","confidence":0,"gaps":["LLM call failed"]}'
        return 1
    }

    # Parse JSON
    local review_json _sr_tmpfile
    _sr_tmpfile=$(mktemp)
    register_temp_file "$_sr_tmpfile"
    printf '%s' "$result" > "$_sr_tmpfile"
    review_json=$(parse_llm_json_object "$_sr_tmpfile" "verdict" 2>/dev/null) || {
        rm -f "$_sr_tmpfile"
        log_worker "Spec review: parse failed — returning error verdict"
        echo '{"verdict":"error","confidence":0,"gaps":["LLM response unparseable"]}'
        return 1
    }
    rm -f "$_sr_tmpfile"

    local verdict confidence
    verdict=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('verdict','pass'))" "$review_json")
    confidence=$(python3 -c "import json,sys; print(json.loads(sys.argv[1]).get('confidence',0))" "$review_json")
    log_worker "Spec review: ${verdict} (confidence: ${confidence})"

    echo "$review_json"
}

