#!/usr/bin/env bash
set -euo pipefail

# farm33 - Standalone implementation farm for vault67-refined specs
# Picks up READY_TO_IMPLEMENT issues, generates code with Ollama, validates, pushes PRs
# Usage: farm33 <command> [args]

# ============================================================================
# Section 1: Preamble + Helpers
# ============================================================================

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WORKTREES_DIR="$SCRIPT_DIR/worktrees"
LOGS_DIR="$SCRIPT_DIR/logs"
PROMPTS_DIR="$SCRIPT_DIR/prompts"
BARE_REPO="$SCRIPT_DIR/.repo.git"
LOCKDIR="$SCRIPT_DIR/.locks"

source "${SCRIPT_DIR}/lib/helpers.bash"
trap safe_cleanup EXIT

load_config() {
    local config_file="$SCRIPT_DIR/.farm33.conf"
    if [ -f "$config_file" ]; then
        # shellcheck source=/dev/null
        source "$config_file"
    fi

    FORGEJO_TOKEN="${FORGEJO_TOKEN:-}"
    FORGEJO_API="${FORGEJO_API:-https://git.logikfabriken.se/api/v1}"
    FORGEJO_REPO="${FORGEJO_REPO:-jesper/Vault67}"

    OLLAMA_URL="${OLLAMA_URL:-http://host.docker.internal:11434}"
    OLLAMA_MODEL="${OLLAMA_MODEL:-qwen2.5-coder:14b}"
    OLLAMA_TIMEOUT="${OLLAMA_TIMEOUT:-300}"

    TARGET_REPO_URL="${TARGET_REPO_URL:-https://git.logikfabriken.se/jesper/Vault67.git}"
    TARGET_REPO_BRANCH="${TARGET_REPO_BRANCH:-main}"

    POOL_SIZE="${POOL_SIZE:-3}"
    BRANCH_PREFIX="${BRANCH_PREFIX:-farm33}"
    POLL_INTERVAL="${POLL_INTERVAL:-60}"
    MAX_RETRIES="${MAX_RETRIES:-2}"

    # Verification gates
    SKIP_SPEC_REVIEW="${SKIP_SPEC_REVIEW:-0}"
    SKIP_TEST_GENERATION="${SKIP_TEST_GENERATION:-0}"
    SKIP_ACCEPTANCE_CHECK="${SKIP_ACCEPTANCE_CHECK:-0}"
    SKIP_DIFF_REVIEW="${SKIP_DIFF_REVIEW:-0}"
    DIFF_REVIEW_THRESHOLD="${DIFF_REVIEW_THRESHOLD:-70}"
    MAX_REFINEMENT_ITERATIONS="${MAX_REFINEMENT_ITERATIONS:-3}"

    mkdir -p "$WORKTREES_DIR" "$LOGS_DIR" "$LOCKDIR"
}

require_api_config() {
    if [ -z "$FORGEJO_TOKEN" ]; then error "FORGEJO_TOKEN not set. Configure in .farm33.conf"; fi
    if [ -z "$FORGEJO_API" ]; then error "FORGEJO_API not set."; fi
    if [ -z "$FORGEJO_REPO" ]; then error "FORGEJO_REPO not set."; fi
}

require_ollama() {
    curl -s --connect-timeout 3 "${OLLAMA_URL}/api/tags" > /dev/null 2>&1 \
        || error "Ollama not reachable at ${OLLAMA_URL}. Run: ollama serve"
}

# ============================================================================
# Section 2: Forgejo API
# ============================================================================

api_request() {
    local method="$1"
    local endpoint="$2"
    local data="${3:-}"

    local url="${FORGEJO_API}${endpoint}"
    local response_file
    response_file=$(mktemp)
    register_temp_file "$response_file"
    local http_code

    if [ -n "$data" ]; then
        http_code=$(curl -s -w "%{http_code}" -X "$method" \
            -H "Authorization: token ${FORGEJO_TOKEN}" \
            -H "Content-Type: application/json" \
            -H "Accept: application/json" \
            -d "$data" \
            "$url" -o "$response_file")
    else
        http_code=$(curl -s -w "%{http_code}" -X "$method" \
            -H "Authorization: token ${FORGEJO_TOKEN}" \
            -H "Accept: application/json" \
            "$url" -o "$response_file")
    fi

    if [[ $http_code -ge 200 && $http_code -lt 300 ]]; then
        cat "$response_file"
        rm -f "$response_file"
        return 0
    else
        local body
        body=$(cat "$response_file")
        rm -f "$response_file"
        echo "API error ${http_code}: ${body}" >&2
        return 1
    fi
}

api_get_issue() {
    local issue_number="$1"
    api_request "GET" "/repos/${FORGEJO_REPO}/issues/${issue_number}"
}

api_get_comments() {
    local issue_number="$1"
    api_request "GET" "/repos/${FORGEJO_REPO}/issues/${issue_number}/comments"
}

api_add_comment() {
    local issue_number="$1"
    local comment_body="$2"
    local json_data
    json_data=$(python3 -c "import json,sys; print(json.dumps({'body':sys.argv[1]}))" "$comment_body")
    api_request "POST" "/repos/${FORGEJO_REPO}/issues/${issue_number}/comments" "$json_data"
}

api_replace_labels() {
    local issue_number="$1"
    shift
    local labels=("$@")
    local json_data
    json_data=$(python3 -c "
import json, sys
labels = sys.argv[1:]
print(json.dumps({'labels': labels}))
" "${labels[@]}")
    api_request "PUT" "/repos/${FORGEJO_REPO}/issues/${issue_number}/labels" "$json_data"
}

api_add_label() {
    local issue_number="$1"
    local label_name="$2"
    local json_data
    json_data=$(python3 -c "import json,sys; print(json.dumps({'labels':[sys.argv[1]]}))" "$label_name")
    api_request "POST" "/repos/${FORGEJO_REPO}/issues/${issue_number}/labels" "$json_data"
}

api_close_issue() {
    local issue_number="$1"
    local json_data
    json_data=$(python3 -c "import json; print(json.dumps({'state':'closed'}))")
    api_request "PATCH" "/repos/${FORGEJO_REPO}/issues/${issue_number}" "$json_data"
}

api_list_ready_issues() {
    local response
    response=$(api_request "GET" "/repos/${FORGEJO_REPO}/issues?state=open&type=issues&labels=state:READY_TO_IMPLEMENT&limit=50")
    echo "$response" | python3 -c "
import sys, json
try:
    issues = json.load(sys.stdin)
    for issue in issues:
        labels = [l['name'] for l in issue.get('labels', [])]
        print(issue['number'])
except:
    pass
"
}

api_create_pull_request() {
    local title="$1"
    local body="$2"
    local head_branch="$3"
    local base_branch="${4:-$TARGET_REPO_BRANCH}"
    local json_data
    json_data=$(python3 -c "
import json, sys
print(json.dumps({
    'title': sys.argv[1],
    'body': sys.argv[2],
    'head': sys.argv[3],
    'base': sys.argv[4]
}))
" "$title" "$body" "$head_branch" "$base_branch")
    api_request "POST" "/repos/${FORGEJO_REPO}/pulls" "$json_data"
}

api_check_deps_resolved() {
    local issue_number="$1"
    local deps_response
    deps_response=$(api_request "GET" "/repos/${FORGEJO_REPO}/issues/${issue_number}/dependencies" 2>/dev/null) || return 0

    python3 -c "
import sys, json
try:
    deps = json.load(sys.stdin)
    if not deps:
        sys.exit(0)
    blockers = [d for d in deps if d.get('state') != 'closed']
    if blockers:
        for b in blockers:
            print(b['number'])
        sys.exit(1)
    sys.exit(0)
except SystemExit:
    raise
except Exception:
    sys.exit(0)
" <<< "$deps_response"
}

